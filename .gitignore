node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Tooling caches
.turbo/
.vite/
.cache/
.eslintcache
coverage/

# Environment files (never commit)
.env
.env.*
!.env.example
*.local

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.vscode/
.idea/

# Python (utilities/)
__pycache__/
*.pyc
*.pyo

# kmcmplib fetch output (generated; do not commit)
packages/compiler/wasm/*.wasm

# kbgen vendored CLDR exemplars (725 files; regenerate via utilities/kbgen/fetch-data.js)
utilities/kbgen/data/cldr/

# CodeGraph local index (dhigby/codegraph)
.codegraph/

# Triage log + scratch state (per-machine; populated by /km-triage)
.escalations/

# Local Claude Code settings (personal API keys, overrides)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Local security-review scratch (per-machine; not a committed artifact)
SECURITY-REVIEW.md

# Diagnostic probe output (Playwright screenshots, ad-hoc dumps)
# Probes write to tmp/ by convention; never commit captures.
tmp/
probe-*.png
probe-*.log
packages/studio/scripts/probe-ewondo-emit.mjs
notes.md

# Playwright run artifacts (packages/studio/e2e)
packages/studio/test-results/
packages/studio/playwright-report/

# repo-map artifact (utilities/hermes/build-repo-map.mjs; written to repo root)
repo-map.json
repo-map*.json

# hermes report artifacts (hermes-run.mjs + vet.mjs both write under utilities/hermes/reports/)
utilities/hermes/reports/

utilities/hermes/repo-map*.json

# Local secrets for the Hermes harness (Context7 etc.) - never commit
utilities/hermes/.env
