  "telemetryInstanceId": "4d5ec64f-97a1-4858-8d93-b8406400eb38",
  "approach": "Add 13 new keyboard-facets (4 P1 + 4 P2 + 5 P3) to the standalone utilities/facet-index tool, each a spec-037 {classify,fallback} archetype registered in DEFAULT_CLASSIFIERS, plus real facet-def YAML and nine session mirrors. Measurement only (spec 039 owns transforms); deterministic from in-repo source, reusing buildProducedSet/base-layout.ts/cause-predicates. One new pinned dep: a CLDR exemplarCharacters snapshot for orthography-coverage-ratio.",
  "decisions": [
    {
      "decision": "Pin a CLDR exemplarCharacters snapshot in-repo under utilities/facet-index/data with a SOURCES.json version pin",
      "why": "orthography-coverage-ratio needs a deterministic reference inventory (FR-004/FR-023); matches how langtags/glottolog/DerivedAge.txt are already pinned",
      "rejected": "Live CLDR fetch or npm dep resolved at build time - breaks byte-determinism, prohibited by FR-004"
    },
    {
      "decision": "Session mirrors only for the nine family-named facets (lineage./source./env./construction.); the four keyboard.* facets are index-only",
      "why": "FR-006 + the clarification pin this; keyboard.* names no session family so a mirror would fail lint contract C4",
      "rejected": "Mirroring all 13 (keyboard.* four have no home family) or none (breaks the two-vocabulary model)"
    },
    {
      "decision": "source.platform-coverage emits modality only (subset of desktop/web/touch) inferred from .kps <Files> extensions, never a <Targets> element",
      "why": "this corpus .kps dialect has no <Targets> (verified vs bambara.kps); file presence cannot distinguish OSes",
      "rejected": "Parsing an assumed <Targets>, or OS-level windows/mac/linux granularity - not derivable from file presence"
    },
    {
      "decision": "Construction session mirrors authored under the source family (source.diacritic-mechanism, source.spare-key-budget), not construction.* — facet-lint has no construction family; matches spec-041 precedent."
    },
    {
      "decision": "diacritic-mechanism heuristic redesigned after review: behavioral add-vs-replace over table-composition (any(base)+key>index(store)), not just dk()/combining output. Validated against the three spec 7.5 A4 exemplars (el_pasifika=stacking, vietnamese_telex=replacing, sil_euro_latin=multi-family)."
    },
    {
      "decision": "OFL categorized permissive in known-licenses.json — confirmed correct by km-domain (matches SIL free/libre intent), resolving km-qc's flag."
    }
  ],
