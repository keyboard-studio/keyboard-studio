  "telemetryInstanceId": "f122ed49-164f-4612-9e56-794b71dcbeaa",
  "approach": "Capture every grapheme in the Type-your-alphabet box (dropping only CR/LF/CRLF/Tab/space, logging unusual chars), then split the inventory in phaseBDraftStore.deriveStores() into Letters/Marks/Accented plus new derived Numbers/Punctuation/Symbols/Separators/Control arrays classified by Unicode General Category. Order each section with a default Intl.Collator, collapse Letters to lowercase with a Show-uppercase toggle (reusing engine caseCounterpart), and keep chars/confirmedInventory complete so the contract stays additive.",
  "decisions": [
    {
      "decision": "Derive the six category arrays once in phaseBDraftStore.deriveStores() as additive studio-store state",
      "why": "Single derivation makes the sections mutually exclusive by construction (FR-005) and directly unit-testable; keeping chars/confirmedInventory complete honors the no-contract-change assumption (FR-013)",
      "rejected": "View-only classification in AlphabetBreakdown, or adding category fields to the ConfirmedAlphabet contract"
    },
    {
      "decision": "{\"decision\": \"Add a pure glyphCategory() primitive to engine character-discovery using native \\p{L|N|P|S|Z|C} escapes\", \"why\": \"The engine already classifies characters exclusively via native Unicode property escapes (isCombiningMarkChar); keeps all GC logic in one package with no UCD table\", \"rejected\": \"A studio-local classifier, or using the generated charnames JSON\"}"
    },
    {
      "decision": "Reuse engine caseCounterpart for the case toggle and record-both-cases; order sections with default Intl.Collator; add a studio-local codepointLabel helper for the U+XXXX+ multi-code-point label",
      "why": "caseCounterpart already encodes the single-code-point/locale/null guards the spec asks for; Intl.Collator is the platform ICU binding (root collation) with no dependency; a local label helper avoids editing the locked toUPlusNotation util (FR-012/FR-014)",
      "rejected": "Raw toUpperCase/code-point sort, or extending toUPlusNotation itself"
    },
    {
      "decision": "T016 gate outcome (a): restrict store bases to letters; route non-letters to derived category arrays",
      "why": "the only ConfirmedAlphabet.bases consumers (marks worklist/attachment-proposals) want letters as attachment bases; complete inventory preserved in flat chars/confirmedInventory (FR-013)",
      "rejected": "view-only p{L} filter (T016a) — unnecessary once no consumer depends on non-letter bases"
    },
    {
      "decision": "relax AlphabetBreakdown render guard to show once any bases exist",
      "why": "US3 requires the Letters section + uppercase toggle to appear for a letters-only alphabet (a b c); existing spec-046 test only asserts marks/accented testids absent, still passes",
      "rejected": "keeping the marks/stack-only guard — would hide Letters for plain alphabets, failing US3"
    }
  ],
  "step_summaries": {
    "plan": {
      "summary": "Studio-only feature (plus one pure engine glyphCategory primitive); no contract/schema edits, all Constitution articles PASS",
      "key_finding": "Every Unicode primitive needed already exists in the engine (caseCounterpart, decomposeGrapheme, isCombiningMarkChar, isPrivateUseCodePoint); the only new engine code is a GC classifier, and phaseBDraftStore.deriveStores() is the single place category routing lands"
    },
    "tasks": {
      "summary": "29 tasks across 7 phases, organized by the four user stories, test-first; MVP = US1 (whole-text capture) + US2 (category breakdown)",
      "key_finding": "US1-US4 implementation tasks all edit packages/studio/src/survey/PhaseB.tsx so they are not parallelizable on that file; Phase 2 primitives (engine glyphCategory, studio codepointLabel + collation) block every story"
    },
    "implement": {
      "summary": "Whole-text grapheme capture + six-way Unicode-GC inventory breakdown (Numbers/Punctuation/Symbols/Separators/Control), ICU-ordered, with Letters case-collapse+uppercase toggle, record-both-cases on Done, letters-only Your-alphabet list, and compact multi-code-point chip labels — studio SPA + one pure engine glyphCategory primitive, no contract change"
    }
  },
