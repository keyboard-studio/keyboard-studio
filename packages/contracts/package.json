{
  "name": "@keyboard-studio/contracts",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript types for keyboard-studio. Day-1 contract per spec.md sections 5, 7, 10, 11.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "import": "./dist/mocks/index.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures/index.d.ts",
      "import": "./dist/fixtures/index.js"
    },
    "./criteria": {
      "types": "./dist/criteriaData.d.ts",
      "import": "./dist/criteriaData.js"
    }
  },
  "files": [
    "dist",
    "src",
    "data",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
