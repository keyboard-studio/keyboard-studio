{
  "name": "@keyboard-studio/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript types for keyboard-studio. Day-1 contract per spec.md sections 5, 7, 10, 11.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^2.0.5"
  }
}
