{
  "name": "@keyboard-studio/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Engine services for keyboard-studio: validator, compiler, scaffolder.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./simulator": {
      "types": "./dist/simulator/index.d.ts",
      "import": "./dist/simulator/index.js"
    },
    "./pattern-schema": {
      "types": "./dist/pattern-library/patternSchema.d.ts",
      "import": "./dist/pattern-library/patternSchema.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm --filter @keyboard-studio/contracts build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@keyboard-studio/contracts": "workspace:*",
    "@keyboard-studio/llm": "workspace:*",
    "@keymanapp/kmc-kmn": "19.0.240-alpha",
    "eventemitter3": "^5.0.4",
    "fflate": "^0.8.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^2.0.5"
  }
}
