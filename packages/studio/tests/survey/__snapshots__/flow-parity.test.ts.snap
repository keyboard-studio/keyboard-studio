exports[`flow-parity: phase_f_helpdocs — questions[] > projected fields are stable (snapshot) > Phase F questions projected 1`] = `
[
  {
    "help_text": "Describe what the keyboard does and who uses it. This text appears at the very top of the keyboard's help page, so write it in plain language that any user can understand. Avoid technical terms. For example: "This keyboard lets you type Bafut (Fa') on any computer. It includes all the tone marks and special letters used in the Bafut alphabet."",
    "id": "pf_welcome_paragraph",
    "next": "pf_usage_tip_1",
    "options": undefined,
    "prompt": "In 1–3 sentences, what is this keyboard for?",
    "required": true,
    "type": "text",
  },
  {
    "help_text": "Give one short tip, for example how to type a character that is not obvious or a key combination for a common accent mark. Keep it to one or two sentences. Screenshots can be added to the keyboard package separately and do not need to be described here.",
    "id": "pf_usage_tip_1",
    "next": "pf_usage_tip_2",
    "options": undefined,
    "prompt": "What is the most important thing to know when using this keyboard?",
    "required": true,
    "type": "text",
  },
  {
    "help_text": "Another short tip about how to use the keyboard. Leave blank if one tip is enough.",
    "id": "pf_usage_tip_2",
    "next": "pf_usage_tip_3",
    "options": undefined,
    "prompt": "Add a second usage tip (optional)",
    "required": false,
    "type": "text",
  },
  {
    "help_text": "Another short tip. Leave blank when done.",
    "id": "pf_usage_tip_3",
    "next": "pf_usage_tip_4",
    "options": undefined,
    "prompt": "Add a third usage tip (optional)",
    "required": false,
    "type": "text",
  },
  {
    "help_text": "Another short tip. Leave blank when done.",
    "id": "pf_usage_tip_4",
    "next": "pf_usage_tip_5",
    "options": undefined,
    "prompt": "Add a fourth usage tip (optional)",
    "required": false,
    "type": "text",
  },
  {
    "help_text": "Another short tip. Leave blank when done.",
    "id": "pf_usage_tip_5",
    "next": "pf_credits",
    "options": undefined,
    "prompt": "Add a fifth usage tip (optional)",
    "required": false,
    "type": "text",
  },
  {
    "help_text": "List the people, organizations, or committees who worked on the keyboard. You can include names, roles, or organizations. For example: "Bafut Language Committee, Northwest Region, Cameroon. Keyboard layout by the Bafut Literacy Project." Do not include a copyright symbol or year — those are captured separately. This appears in the credits section of the help page.",
    "id": "pf_credits",
    "next": "pf_contact_info",
    "options": undefined,
    "prompt": "Who should be acknowledged for creating this keyboard?",
    "required": false,
    "type": "text",
  },
  {
    "help_text": "An email address, website, or social media handle where people can reach the language community. This appears at the end of the help page so users can ask questions or report problems. Leave blank to omit it.",
    "id": "pf_contact_info",
    "next": null,
    "options": undefined,
    "prompt": "Is there a public contact for the language community? (optional)",
    "required": false,
    "type": "text",
  },
]
`;
