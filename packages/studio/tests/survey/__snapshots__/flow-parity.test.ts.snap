// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`flow-parity: identity_lite — questions[] > projected fields are stable (snapshot) > identity_lite questions projected 1`] = `
[
  {
    "help_text": "Type the name your community uses for the language, using your own spelling and characters. For example: Fà', Kiswahili, हिन्दी.",
    "id": "il_language_autonym",
    "next": "il_language_english",
    "options": undefined,
    "prompt": "What is your language called in your own language?",
    "required": true,
    "type": "text",
  },
  {
    "help_text": "The English name used in directories and official language lists, for example: Bafut, Swahili, Hindi. If your language has no widely-used English name, repeat the name you gave above.",
    "id": "il_language_english",
    "next": "il_language_code",
    "options": undefined,
    "prompt": "What is your language called in English?",
    "required": true,
    "type": "text",
  },
  {
    "help_text": "Enter the two- or three-letter ISO 639 code for your language — the short code linguists and software systems use to identify it. Examples: "en" (English), "fr" (French), "ha" (Hausa), "hi" (Hindi), "sw" (Swahili), "bft" (Balti). Leave blank if you are unsure; you can add it later. Note: enter only the language subtag, not a full BCP47 tag with region or variant (those are added during the documentation stage).",
    "id": "il_language_code",
    "next": "il_target_script",
    "options": undefined,
    "prompt": "What is the ISO 639 language subtag for this language?",
    "required": false,
    "type": "text",
  },
  {
    "help_text": "Choose the writing system this keyboard produces. It can differ from the script your language normally uses: pick "Latin romanization" or "IPA" if you are building a romanized or phonetic keyboard. The script you choose here — not the language — decides the keyboard's layout family.",
    "id": "il_target_script",
    "next": [
      {
        "condition": "value == 'Ethi' or value == 'Hani' or value == 'Hang'",
        "goto": "il_script_not_supported",
      },
      {
        "default": true,
        "goto": null,
      },
    ],
    "options": [
      {
        "label": "Latin (A–Z and accented letters like é, ñ, ŋ)",
        "value": "Latn",
      },
      {
        "label": "Latin romanization (the keyboard produces Latin letters A–Z and diacritics)",
        "value": "romanization-Latn",
      },
      {
        "label": "IPA — phonetic transcription (Latin-based)",
        "value": "fonipa",
      },
      {
        "label": "Arabic",
        "value": "Arab",
      },
      {
        "label": "Hebrew",
        "value": "Hebr",
      },
      {
        "label": "Devanagari (Hindi, Nepali, Marathi, and others)",
        "value": "Deva",
      },
      {
        "label": "Cyrillic (Russian, Ukrainian, Serbian, and others)",
        "value": "Cyrl",
      },
      {
        "label": "Greek",
        "value": "Grek",
      },
      {
        "label": "Georgian",
        "value": "Geor",
      },
      {
        "label": "Armenian",
        "value": "Armn",
      },
      {
        "label": "Ethiopic (Ge'ez, Amharic, Tigrinya — not yet supported)",
        "value": "Ethi",
      },
      {
        "label": "Chinese / Japanese Han characters (not yet supported)",
        "value": "Hani",
      },
      {
        "label": "Hangul (Korean — not yet supported)",
        "value": "Hang",
      },
      {
        "label": "Another script not listed here",
        "value": "other",
      },
    ],
    "prompt": "Which script will THIS keyboard type?",
    "required": true,
    "type": "select",
  },
  {
    "help_text": "This version does not yet support Ethiopic, Han (Chinese/Japanese), or Hangul keyboards. Hangul needs jamo-to-syllable composition; Ethiopic and Han need reorder / IME candidate work — neither is built yet. You can close this form for now; nothing you entered will be submitted.",
    "id": "il_script_not_supported",
    "next": null,
    "options": undefined,
    "prompt": "This writing system is not supported yet",
    "required": false,
    "type": "notice",
  },
]
`;

