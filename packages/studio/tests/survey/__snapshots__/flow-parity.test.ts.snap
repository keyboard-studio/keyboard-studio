        "value": "mobile",
      },
      {
        "label": "Both desktop and mobile",
        "value": "both",
      },
    ],
    "prompt": "Is this keyboard primarily for mobile (touchscreen) or desktop (physical keyboard) use?",
    "required": false,
    "type": "radio",
  },
  {
    "help_text": "This name will appear in the keyboard package and in the public keyboard repository. You can use a person's name, an organization name, or a committee name, for example: Bafut Language Committee.",
    "id": "author_display_name",
    "next": "author_contact_email",
    "options": undefined,
    "prompt": "Who should be listed as the author of this keyboard?",
    "required": true,
    "type": "text",
  },
  {
    "help_text": "This address goes into the keyboard package so that users or maintainers can reach the right person if they have questions. Use an address that will remain active.",
    "id": "author_contact_email",
    "next": "pa_copyright_holder",
    "options": undefined,
    "prompt": "What email address can people use to contact the keyboard author?",
    "required": true,
    "type": "text",
  },
  {
    "help_text": "Name of the person or organization that holds the copyright for this keyboard. This may be you, your employer, or a language organization. Example: 'Bafut Language Committee'",
    "id": "pa_copyright_holder",
    "next": "provenance_opt_in",
    "options": undefined,
    "prompt": "Who holds the copyright for this keyboard?",
    "required": true,
    "type": "short_text",
  },
  {
    "help_text": "This optional section collects context about who is requesting the keyboard and the language community it serves. None of it is required, and none of it affects how the keyboard is built. It helps reviewers understand the project.",
    "id": "provenance_opt_in",
    "next": [
