{
  "name": "@keyboard-studio/studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The spec'd authoring SPA. Two-pane survey + live preview per spec.md §4 (issue #22 et al).",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm --filter @keyboard-studio/contracts --filter @keyboard-studio/engine --filter @keymanapp/keyboard-lint run build",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/build-keyboards-index.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "messages:extract": "lingui extract",
    "messages:compile": "lingui compile",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@keyboard-studio/contracts": "workspace:*",
    "@keyboard-studio/engine": "workspace:*",
    "@keyboard-studio/glottolog": "workspace:*",
    "@keymanapp/keyboard-lint": "workspace:*",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^6.5.0",
    "@lingui/cli": "^6.5.0",
    "@lingui/format-json": "^6.5.0",
    "@lingui/vite-plugin": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "fflate": "^0.8.3",
    "jsdom": "^26.0.0",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.6"
  }
}
