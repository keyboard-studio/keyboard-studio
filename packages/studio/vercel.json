{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/kbd-proxy/:path*",
      "destination": "https://raw.githubusercontent.com/keymanapp/keyboards/master/:path*"
    },
    {
      "source": "/local-kbd-proxy/:path*",
      "destination": "https://raw.githubusercontent.com/keymanapp/keyboards/master/:path*"
    }
  ]
}
