{
  "name": "@keyboard-studio/studio-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "POC dev interface — in-browser kmcmplib + kmw-compiler + KMW iframe preview. Keep as a working reference; the real spec'd UI lives in @keyboard-studio/studio.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@keyboard-studio/contracts": "workspace:*",
    "@keyboard-studio/engine": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.6"
  }
}
