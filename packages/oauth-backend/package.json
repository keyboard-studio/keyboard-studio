{
  "name": "@keyboard-studio/oauth-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal OAuth token-exchange backend for the GitHub fork+PR delivery path.",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch --preserveWatchOutput",
    "clean": "tsc -b --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
