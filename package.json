{
  "name": "keyboard-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo root for keyboard-studio. See spec.md.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "fetch-langtags": "node scripts/fetch-langtags.mjs",
    "codegen-langtags": "node scripts/codegen-langtags.mjs",
    "fetch-glottolog": "node scripts/fetch-glottolog.mjs",
    "codegen-glottolog": "node scripts/codegen-glottolog.mjs",
    "compile-recognizer-rules": "node scripts/compile-recognizer-rules.mjs",
    "codegen-charnames": "node scripts/codegen-charnames.mjs",
    "prebuild": "pnpm run fetch-langtags && pnpm run codegen-langtags && pnpm run fetch-glottolog && pnpm run codegen-glottolog && pnpm run compile-recognizer-rules && pnpm run codegen-charnames",
    "build": "pnpm -r build",
    "dev": "pnpm --filter @keyboard-studio/engine build && pnpm --parallel --stream --filter @keyboard-studio/engine --filter @keyboard-studio/studio run dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\" && pnpm run depcruise && pnpm run crew-lint && pnpm run facet-lint && pnpm run facet-index-lint && pnpm run adaptation-catalog-lint && pnpm run i18n-catalog-lint && pnpm run test-antipattern-lint",
    "depcruise": "depcruise --config .dependency-cruiser.cjs packages/*/src",
    "crew-lint": "node utilities/crew-lint/index.js",
    "facet-lint": "node utilities/facet-lint/index.js",
    "facet-index-lint": "node utilities/facet-index-lint/index.js",
    "adaptation-catalog-lint": "node utilities/adaptation-catalog-lint/index.js",
    "i18n-catalog-lint": "node utilities/i18n-catalog-lint/index.js",
    "test-antipattern-lint": "node utilities/test-antipattern-lint/index.js",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,json,md}\"",
    "crowdin:upload": "crowdin upload sources -b main",
    "crowdin:download": "crowdin download -b main"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.14.4",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  }
}
